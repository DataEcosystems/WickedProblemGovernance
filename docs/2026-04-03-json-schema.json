{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "ArchitectureType": {
      "$ref": "#/$defs/ArchitectureType"
    },
    "Artifact": {
      "$ref": "#/$defs/Artifact"
    },
    "ArtifactType": {
      "$ref": "#/$defs/ArtifactType"
    },
    "Domain": {
      "$ref": "#/$defs/Domain"
    },
    "Ecosystem": {
      "$ref": "#/$defs/Ecosystem"
    },
    "Episode": {
      "$ref": "#/$defs/Episode"
    },
    "Event": {
      "$ref": "#/$defs/Event"
    },
    "EventType": {
      "$ref": "#/$defs/EventType"
    },
    "InstitutionalLayer": {
      "$ref": "#/$defs/InstitutionalLayer"
    },
    "Partner": {
      "$ref": "#/$defs/Partner"
    },
    "Project": {
      "$ref": "#/$defs/Project"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ArchitectureType": {
      "type": "string",
      "enum": [
        "custodial",
        "federated"
      ],
      "id": "ArchitectureType"
    },
    "Artifact": {
      "id": "Artifact",
      "readOnly": true,
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/__schema0"
        },
        "partnerIds": {
          "readOnly": true,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        "type": {
          "$ref": "#/$defs/ArtifactType"
        }
      },
      "required": [
        "id",
        "partnerIds",
        "type"
      ],
      "additionalProperties": false
    },
    "__schema0": {
      "type": "string"
    },
    "ArtifactType": {
      "type": "string",
      "enum": [
        "committee_minutes",
        "email",
        "signed_agreement"
      ],
      "id": "ArtifactType"
    },
    "Domain": {
      "id": "Domain",
      "readOnly": true,
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/__schema0"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "additionalProperties": false
    },
    "Ecosystem": {
      "id": "Ecosystem",
      "readOnly": true,
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/__schema0"
        },
        "meanNormalizedBurden": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "meanTimeToValue": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "projectIds": {
          "readOnly": true,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        "stdTimeToValue": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "id",
        "meanNormalizedBurden",
        "meanTimeToValue",
        "name",
        "projectIds",
        "stdTimeToValue"
      ],
      "additionalProperties": false
    },
    "Episode": {
      "id": "Episode",
      "readOnly": true,
      "type": "object",
      "properties": {
        "couplingProxy": {
          "type": "number"
        },
        "domainHeterogeneity": {
          "type": "number"
        },
        "eventIds": {
          "readOnly": true,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        "id": {
          "$ref": "#/$defs/__schema0"
        },
        "layerHeterogeneity": {
          "type": "number"
        },
        "normalizedBurden": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "partnerCount": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "partnerIds": {
          "readOnly": true,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        "stall": {
          "type": "boolean"
        },
        "t0": {
          "$ref": "#/$defs/__schema1"
        },
        "t1": {
          "anyOf": [
            {
              "$ref": "#/$defs/__schema1"
            },
            {
              "type": "null"
            }
          ]
        },
        "t2": {
          "anyOf": [
            {
              "$ref": "#/$defs/__schema1"
            },
            {
              "type": "null"
            }
          ]
        },
        "tau1": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "tau2": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "couplingProxy",
        "domainHeterogeneity",
        "eventIds",
        "id",
        "layerHeterogeneity",
        "normalizedBurden",
        "partnerCount",
        "partnerIds",
        "stall",
        "t0",
        "t1",
        "t2",
        "tau1",
        "tau2"
      ],
      "additionalProperties": false
    },
    "__schema1": {
      "anyOf": [
        {
          "type": "string",
          "format": "date",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))$"
        },
        {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        }
      ]
    },
    "Event": {
      "id": "Event",
      "readOnly": true,
      "type": "object",
      "properties": {
        "artifactId": {
          "$ref": "#/$defs/__schema0"
        },
        "id": {
          "$ref": "#/$defs/__schema0"
        },
        "timestamp": {
          "$ref": "#/$defs/__schema1"
        },
        "type": {
          "$ref": "#/$defs/EventType"
        }
      },
      "required": [
        "artifactId",
        "id",
        "timestamp",
        "type"
      ],
      "additionalProperties": false
    },
    "EventType": {
      "type": "string",
      "enum": [
        "agreement_executed",
        "approval_issued",
        "request_submitted"
      ],
      "id": "EventType"
    },
    "InstitutionalLayer": {
      "id": "InstitutionalLayer",
      "readOnly": true,
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/__schema0"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "additionalProperties": false
    },
    "Partner": {
      "id": "Partner",
      "readOnly": true,
      "type": "object",
      "properties": {
        "domainIds": {
          "readOnly": true,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        "id": {
          "$ref": "#/$defs/__schema0"
        },
        "layerIds": {
          "readOnly": true,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "domainIds",
        "id",
        "layerIds",
        "name"
      ],
      "additionalProperties": false
    },
    "Project": {
      "id": "Project",
      "readOnly": true,
      "type": "object",
      "properties": {
        "architectureType": {
          "$ref": "#/$defs/ArchitectureType"
        },
        "deliveryCouplingProxy": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "deliveryEpisodeId": {
          "anyOf": [
            {
              "$ref": "#/$defs/__schema0"
            },
            {
              "type": "null"
            }
          ]
        },
        "episodeCount": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "episodeIds": {
          "readOnly": true,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        "id": {
          "$ref": "#/$defs/__schema0"
        },
        "normalizedBurden": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "partnerCount": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "stallFraction": {
          "type": "number"
        },
        "stewardPresence": {
          "type": "boolean"
        },
        "t0": {
          "$ref": "#/$defs/__schema1"
        },
        "tau2": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "architectureType",
        "deliveryCouplingProxy",
        "deliveryEpisodeId",
        "episodeCount",
        "episodeIds",
        "id",
        "normalizedBurden",
        "partnerCount",
        "stallFraction",
        "stewardPresence",
        "t0",
        "tau2"
      ],
      "additionalProperties": false
    }
  }
}
