{
  "@context": {
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "wpg": "https://purl.dataecosystems.org/wpg/ontology#",

    "Architecture": "wpg:Architecture",
