      "@type": "@id",
      "@container": "@set"
    },
    "ecosystem": {
      "@id": "wpg:ecosystem",
      "@type": "@id"
    },
    "episode": {
      "@id": "wpg:episode",
      "@type": "@id"
    },
    "episodeCount": "wpg:episodeCount",
