{
  "compilerOptions": {
    "baseUrl": "src",
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": false,
    "outDir": "dist",
    "sourceMap": true
  },
  "extends": [
    "@tsconfig/strictest/tsconfig.json"
  ],
  "include": [
    "src/**/*.ts"
  ]
}