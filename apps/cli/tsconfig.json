{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,
    "lib": [
      "ES2022"
    ],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noUncheckedIndexedAccess": false,
    "outDir": "dist",
    "resolveJsonModule": true,
    "rootDir": "src",
    "target": "es2022",
    "types": [
      "node"
    ]
  },
  "extends": [
    "@tsconfig/strictest/tsconfig.json"
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.json"
  ]
}